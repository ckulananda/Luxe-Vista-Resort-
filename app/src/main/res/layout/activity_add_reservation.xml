<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Reservation"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="12dp"
            android:background="#6200EE"
            android:textColor="@android:color/white"/>

        <!-- User Info -->
        <TextView
            android:id="@+id/tvUserInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="User Info"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            android:gravity="center"/>

        <!-- Type Spinner -->
        <Spinner
            android:id="@+id/spinnerType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:minHeight="48dp" />

        <!-- Service Name Spinner -->
        <Spinner
            android:id="@+id/spinnerServiceName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="48dp" />

        <!-- Service Details -->
        <TextView
            android:id="@+id/tvServiceDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Service Details will appear here"
            android:textSize="16sp"
            android:layout_marginTop="12dp"
            android:padding="8dp"
            android:background="#f0f0f0"
            android:textColor="#000"/>

        <!-- Date Picker -->
        <Button
            android:id="@+id/btnSelectDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Date"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/tvSelectedDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No date selected"
            android:layout_marginTop="8dp"
            android:gravity="center"/>

        <!-- Add Reservation Button -->
        <Button
            android:id="@+id/btnAddReservation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirm Reservation"
            android:layout_marginTop="24dp"
            android:background="#6200EE"
            android:textColor="@android:color/white"/>
    </LinearLayout>
</ScrollView>
